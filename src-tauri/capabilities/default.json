{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window: persistent store, open links, native dialogs.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "store:default",
    "shell:allow-open",
    "dialog:default",
    "updater:default",
    "process:default"
  ]
}
